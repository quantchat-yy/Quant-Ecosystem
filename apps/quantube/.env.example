PORT=3005
JWT_SECRET=dev-secret-change-in-production
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://quant:quant@localhost:5432/quantdb

# --- Task 13.2: payments (Stripe) ---
# Read from secrets/config ONLY — never hardcode a real key (Req 7.6). Stripe
# TEST MODE is acceptable for the DoD (design Open Question 3): when unset, the
# backend falls back to non-functional TEST placeholders so the gateway still
# constructs and webhook signature verification stays exercisable without a live
# key. Use your `sk_test_…` / `whsec_…` test values locally.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Single source of truth for the quantube backend origin used by the Next.js
# engine proxies (Layer 4). Defaults to the backend PORT (3006) when unset.
NEXT_PUBLIC_QUANTUBE_BACKEND_URL=http://localhost:3006
