{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "paths": {
      "@quant/common": ["../../packages/common/src/index.ts"],
      "@quant/common/*": ["../../packages/common/src/*"],
      "@quant/auth": ["../../packages/auth/src/index.ts"],
      "@quant/auth/*": ["../../packages/auth/src/*"],
      "@quant/database": ["../../packages/database/dist/index.d.ts"],
      "@quant/database/*": ["../../packages/database/dist/*"],
      "@quant/realtime": ["../../packages/realtime/src/index.ts"],
      "@quant/realtime/*": ["../../packages/realtime/src/*"],
      "@quant/server-core": ["../../packages/server-core/src/index.ts"],
      "@quant/server-core/*": ["../../packages/server-core/src/*"],
      "@quant/ai": ["../../packages/ai/src/index.ts"],
      "@quant/ai/*": ["../../packages/ai/src/*"],
      "@quant/ai-memory": ["../../packages/ai-memory/src/index.ts"],
      "@quant/ai-memory/*": ["../../packages/ai-memory/src/*"],
      "@quant/ab-testing": ["../../packages/ab-testing/src/index.ts"],
      "@quant/ab-testing/*": ["../../packages/ab-testing/src/*"],
      "@quant/agentic": ["../../packages/agentic/src/index.ts"],
      "@quant/agentic/*": ["../../packages/agentic/src/*"],
      "@quant/cache": ["../../packages/cache/src/index.ts"],
      "@quant/cache/*": ["../../packages/cache/src/*"],
      "@quant/cdn": ["../../packages/cdn/src/index.ts"],
      "@quant/cdn/*": ["../../packages/cdn/src/*"],
      "@quant/events": ["../../packages/events/src/index.ts"],
      "@quant/events/*": ["../../packages/events/src/*"],
      "@quant/ml": ["../../packages/ml/src/index.ts"],
      "@quant/ml/*": ["../../packages/ml/src/*"],
      "@quant/moderation": ["../../packages/moderation/src/index.ts"],
      "@quant/moderation/*": ["../../packages/moderation/src/*"],
      "@quant/payment": ["../../packages/payment/src/index.ts"],
      "@quant/payment/*": ["../../packages/payment/src/*"],
      "@quant/recommendation": ["../../packages/recommendation/src/index.ts"],
      "@quant/recommendation/*": ["../../packages/recommendation/src/*"],
      "@quant/scaling": ["../../packages/scaling/src/index.ts"],
      "@quant/scaling/*": ["../../packages/scaling/src/*"],
    }
  },
  "include": ["backend/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "app"]
}
