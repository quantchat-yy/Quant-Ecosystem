          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total[$interval])) / (sum by (service) (rate(infrastructure_cost_usd_total[$interval])) > 0)",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ],
      "title": "Request Volume vs Cost Ratio (Requests per Dollar)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          },
          "unit": "percentunit",
          "max": 1,
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(increase(infrastructure_cost_usd_total[30d])) / on() group_left() monthly_budget_usd",
          "legendFormat": "Total Budget Consumption",
          "refId": "A"
        },
        {
          "expr": "sum(increase(ai_provider_token_cost_usd_total[30d])) / on() group_left() monthly_ai_budget_usd",
          "legendFormat": "AI Budget Consumption",
          "refId": "B"
        }
      ],
      "title": "Budget Consumption Rate (30d Rolling)",
      "type": "gauge"
