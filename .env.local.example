# =============================================================================
# Quant Ecosystem - Local Development Environment Variables
# Copy this file to .env.local and fill in values as needed
# =============================================================================

# Database
DATABASE_URL=postgresql://quant:quant@localhost:5432/quantdb

# Redis
REDIS_URL=redis://localhost:6379

# Object Storage (S3-compatible / MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=quant-uploads

# Email (MailHog for development)
SMTP_HOST=localhost
SMTP_PORT=1025

# Search
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=masterKey

# Event Streaming
NATS_URL=nats://localhost:4222
KAFKA_BROKERS=localhost:9092

# Vector Database
QDRANT_HOST=http://localhost
QDRANT_PORT=6333

# Embeddings
EMBEDDING_PROVIDER=

# Auth
JWT_SECRET=development-only-change-in-production
JWT_ISSUER=https://auth.quant-ecosystem.dev

# AI (optional for development)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# App Ports
QUANTMAIL_PORT=3001
QUANTCHAT_PORT=3002
QUANTAI_PORT=3003
QUANTSYNC_PORT=3004
QUANTUBE_PORT=3005
QUANTADS_PORT=3006
QUANTMAX_PORT=3007
QUANTNEON_PORT=3008
QUANTEDITS_PORT=3009
QUANTMEET_PORT=3010
QUANTDOCS_PORT=3011
QUANTDRIVE_PORT=3012
QUANTCALENDAR_PORT=3013

# Service Ports
GIT_SERVER_PORT=3020
CI_RUNNER_PORT=3021
SEARCH_INDEXER_PORT=3022
MODERATION_WORKER_PORT=3023
CDC_RELAY_PORT=3024
SMTP_INBOUND_PORT=3025
